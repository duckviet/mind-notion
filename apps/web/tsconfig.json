{
  "extends": "@mind-notion/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "preserveSymlinks": true,
    "paths": {
      "@/*": ["./*"],
      "@tiptap/*": ["./node_modules/@tiptap/*"],
      "@chenglou/pretext": ["./node_modules/@chenglou/pretext"],
      "katex": ["./node_modules/katex"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
