AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8090
AI_SERVICE_RELOAD=true

OPENAI_API_KEY=your-openai-api-key

# Internal auth token for calling /internal/v1/agent/* endpoints
AI_INTERNAL_TOKEN=dev-ai-service-token

# Backend API base URL (Go backend)
BACKEND_INTERNAL_BASE_URL=http://localhost:8080
BACKEND_INTERNAL_TOKEN=dev-ai-service-token
BACKEND_TOOL_TIMEOUT_MS=30000

# Optional fallback token used by agent/tools/notes.py when BACKEND_INTERNAL_TOKEN is empty
AI_SERVICE_TOKEN=

# RAG chunking + embedding
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNKS_OUTPUT_DIR=./rag/data/chunks
EMBED_URL=https://vuttc-bge-m3-onnx.hf.space/embed
