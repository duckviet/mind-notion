# Copy values from backend/.env or override here
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=collaborative_editor
DATABASE_SSL_MODE=disable

# Chunking config
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Output config
CHUNKS_OUTPUT_DIR=./data/chunks

# ONNX model source (optional)
# Nếu không set, code sẽ ưu tiên thư mục local ./bge_m3_onnx
# Nếu muốn tải từ Hugging Face Hub, set repo id như: your-org/your-bge-m3-onnx
HF_ONNX_REPO_ID=
HF_ONNX_REVISION=main
# 1 = luôn tải từ HF kể cả khi có local, 0 = ưu tiên local
HF_ONNX_FORCE_DOWNLOAD=0
