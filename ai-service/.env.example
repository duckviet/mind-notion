# Copy values from backend/.env or override here
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=collaborative_editor
DATABASE_SSL_MODE=disable

# Chunking config
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Output config
CHUNKS_OUTPUT_DIR=./data/chunks
STATE_FILE=./state/ingest_state.json
